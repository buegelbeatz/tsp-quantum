# @env REQUIRED | purpose: GitHub API authentication for board, wiki, and repository automation | format: classic token or fine-grained token
GH_TOKEN=""

# @env OPTIONAL | purpose: Required token scopes for GH token report validation | format: comma-separated list
GH_REQUIRED_SCOPES="repo,project,read:org,read:discussion"

# @env OPTIONAL | purpose: Claude API token for AI assistant integration | format: secret token
CLAUDE_TOKEN=""

# @env OPTIONAL | purpose: OpenAI-compatible endpoint used for image/video vision labeling | format: full HTTPS chat/completions URL
DIGITAL_TEAM_VISION_API_URL="https://models.inference.ai.azure.com/chat/completions"

# @env OPTIONAL | purpose: API key for vision endpoint; can reuse GH_TOKEN when using GitHub Models | format: secret token
DIGITAL_TEAM_VISION_API_KEY=""

# @env OPTIONAL | purpose: Vision-capable model name used for image/video description and labels | format: model identifier string
DIGITAL_TEAM_VISION_MODEL="gpt-4o-mini"

# @env OPTIONAL | purpose: Maximum number of video frames sampled for vision labeling to control runtime cost | format: integer 1..6
DIGITAL_TEAM_VISION_VIDEO_MAX_FRAMES="2"

# @env OPTIONAL | purpose: Maximum adaptive sample points per video vision analysis after diff-based refinement | format: integer 2..8
DIGITAL_TEAM_VISION_VIDEO_MAX_POINTS="3"

# @env OPTIONAL | purpose: Minimum wait time between vision API calls to reduce rate-limit pressure | format: decimal seconds
DIGITAL_TEAM_VISION_MIN_REQUEST_SPACING="1.5"

# @env OPTIONAL | purpose: Number of retries for 429 rate-limit responses from the vision backend | format: integer 0..8
DIGITAL_TEAM_VISION_RETRIES="2"

# @env OPTIONAL | purpose: Base backoff delay used when rate-limit headers are missing | format: decimal seconds
DIGITAL_TEAM_VISION_RETRY_DELAY="1.5"

# @env OPTIONAL | purpose: Klaxoon OAuth 2.0 client ID for app-based authentication | format: secret credential (do not commit, required for board import)
KLAXOON_CLIENT_ID=""

# @env OPTIONAL | purpose: Klaxoon OAuth 2.0 client secret for token generation | format: secret credential (do not commit, required for board import)
KLAXOON_CLIENT_SECRET=""

# @env OPTIONAL | purpose: Klaxoon API base URL for REST endpoints (board ID will be extracted from source URLs) | format: https://api.klaxoon.com/v1
KLAXOON_API_URL="https://api.klaxoon.com/v1"

# @env OPTIONAL | purpose: Override default registry owner for container publication workflows when repository owner must not be used directly | format: GitHub org or user name
GHCR_OWNER_OVERRIDE=""

